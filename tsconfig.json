{
  "compilerOptions": {
    "target": "ES2017",
    "module": "commonjs",
    "lib": ["ES2017"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "resolveJsonModule": true,
    "declaration": true
  },
  "include": ["pipeline/**/*.ts"],
  "exclude": ["node_modules", "dashboard-next", "dashboard"]
}
